generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Role: READER | WRITER | ADMIN
// NovelStatus: DRAFT | ONGOING | COMPLETED | HIATUS
// TransactionType: TOPUP | PURCHASE | EARNING | DONATION_SENT | DONATION_RECEIVED

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  penName       String?
  avatar        String?
  bio           String?
  role          String   @default("READER")
  isBanned      Boolean  @default(false)
  coinBalance       Int       @default(0)
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  emailVerified              DateTime?
  emailVerifyToken           String?   @unique
  emailVerifyTokenExpiresAt  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  novels            Novel[]
  chapters          Chapter[]
  comments          Comment[]
  bookmarks         Bookmark[]
  readingProgress   ReadingProgress[]
  transactions      CoinTransaction[]
  donationsSent     Donation[]         @relation("DonationSender")
  donationsReceived Donation[]         @relation("DonationReceiver")
  notifications     Notification[]
  deviceTokens      DeviceToken[]
  reports           Report[]
  payoutRequests    PayoutRequest[]
  paymentOrders     PaymentOrder[]
  reviews           Review[]
  following         Follow[]           @relation("UserFollowing")
  followers         Follow[]           @relation("UserFollowers")

  @@map("users")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  rating    Int
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, novelId])
  @@index([novelId])
  @@map("reviews")
}

// PaymentOrder status: PENDING | PAID | FAILED | EXPIRED | CANCELLED
model PaymentOrder {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId     String
  coinAmount    Int
  bonusAmount   Int       @default(0)
  priceThb      Int
  refNo         String    @unique
  provider      String    @default("paysolutions")
  providerTxnId String?
  status        String    @default("PENDING")
  rawPostback   Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  paidAt        DateTime?
  expiresAt     DateTime

  @@index([userId])
  @@index([status])
  @@index([refNo])
  @@map("payment_orders")
}

// PayoutRequest status: PENDING | APPROVED | REJECTED | PAID
model PayoutRequest {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCoins     Int
  amountThb       Int
  bankName        String
  bankAccount     String
  bankAccountName String
  status          String    @default("PENDING")
  adminNote       String?
  requestedAt     DateTime  @default(now())
  processedAt     DateTime?

  @@index([userId])
  @@index([status])
  @@map("payout_requests")
}

model Genre {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  icon   String?
  novels Novel[]

  @@map("genres")
}

model Novel {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  synopsis    String
  coverImage  String?
  status      String   @default("DRAFT")
  isAdult     Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  viewCount   Int      @default(0)
  averageRating Float  @default(0)
  reviewCount   Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  genreId String
  genre   Genre  @relation(fields: [genreId], references: [id])

  chapters  Chapter[]
  bookmarks Bookmark[]
  tags      Tag[]
  reviews   Review[]

  @@index([authorId])
  @@index([genreId])
  @@index([status])
  @@map("novels")
}

model Chapter {
  id          String    @id @default(cuid())
  number      Int
  title       String
  content     String
  wordCount   Int       @default(0)
  coinPrice   Int       @default(0)
  isFree      Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  novelId String
  novel   Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  comments        Comment[]
  purchases       ChapterPurchase[]
  readingProgress ReadingProgress[]

  @@unique([novelId, number])
  @@index([novelId])
  @@map("chapters")
}

model Tag {
  id     String  @id @default(cuid())
  name   String  @unique
  novels Novel[]

  @@map("tags")
}

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  novelId String
  novel   Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("bookmarks")
}

model ReadingProgress {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@map("reading_progress")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("comments")
}

model ChapterPurchase {
  id        String   @id @default(cuid())
  coinSpent Int
  createdAt DateTime @default(now())

  userId    String
  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id])

  @@unique([userId, chapterId])
  @@map("chapter_purchases")
}

model CoinTransaction {
  id          String   @id @default(cuid())
  type        String
  amount      Int
  description String
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("coin_transactions")
}

model Donation {
  id        String   @id @default(cuid())
  amount    Int
  message   String?
  createdAt DateTime @default(now())

  senderId   String
  sender     User   @relation("DonationSender", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("DonationReceiver", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@map("donations")
}

// NotificationType: NEW_CHAPTER | COMMENT | DONATION | SYSTEM
model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model DeviceToken {
  id        String   @id @default(cuid())
  token     String
  platform  String   // "ios" | "android" | "web"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@map("device_tokens")
}

// ReportTargetType: COMMENT | NOVEL | CHAPTER
// ReportStatus: PENDING | RESOLVED | DISMISSED
model Report {
  id         String   @id @default(cuid())
  targetType String
  targetId   String
  reason     String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetType, targetId])
  @@index([reporterId])
  @@map("reports")
}
